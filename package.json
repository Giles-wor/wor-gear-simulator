{
  "name": "wor-dps-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "sync:heroes": "node scripts/sync-heroes.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:v1": "tsc --noEmit -p v1/tsconfig.json",
    "dev": "vite",
    "dev:v1": "vite --config v1/vite.config.ts",
    "build": "npm run typecheck && vite build",
    "build:v1": "npm run typecheck:v1 && vite build --config v1/vite.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
